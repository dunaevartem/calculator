# Шаг 1: Используем легкий образ для запуска
FROM alpine:3.19

# Устанавливаем необходимые библиотеки для работы Go-бинарника (если есть зависимости от C)
RUN apk add --no-cache ca-certificates libc6-compat

# Копируем скомпилированный бинарник из артефактов GitLab (стадия build)
COPY app /app

# ОБЯЗАТЕЛЬНО копируем папку с шаблонами, так как твой код ищет их в runtime
COPY templates /templates

# Выставляем порт, который слушает Gin
EXPOSE 8080

# Запускаем приложение
ENTRYPOINT ["/app"]
